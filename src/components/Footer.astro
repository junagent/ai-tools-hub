---
import type { Locale } from '../i18n/config';
import { getTranslation } from '../i18n/server';

const locale: Locale = Astro.locals.locale || 'zh';
const translation = getTranslation(locale);
---

<footer class="bg-gray-50 dark:bg-gray-950 border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-gray-900 dark:text-white mb-4" aria-label="AI Tools Hub Home">
          <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="32" height="32" rx="8" fill="currentColor"/>
            <path d="M8 12h16M8 16h12M8 20h8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          <span>AI Tools Hub</span>
        </a>
        <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-6 max-w-xs">
          {translation.footer.description}
        </p>
        <div class="flex items-center gap-4">
          <a href="https://github.com/junagent/ai-tools-hub" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 9.124H15.3l-7.58-8.229L0.687 21.75H7.665l7.746-8.601L21.519 24H24l-10.226-11.584L24 2.25h-3.297l-6.568 7.59-8.077-9.06z"/>
            </svg>
          </a>
          <a href="mailto:hello@ai-tools-hub.example.com" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Email">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <nav aria-label={translation.footer.quickLinks}>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">{translation.footer.quickLinks}</h3>
        <ul class="space-y-3">
          <li><a href="/" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.nav.home}</a></li>
          <li><a href="/tools" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.nav.tools}</a></li>
          <li><a href="/categories" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.nav.categories}</a></li>
          <li><a href="/blog" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.nav.blog}</a></li>
          <li><a href="/submit" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.nav.submitTool}</a></li>
        </ul>
      </nav>

      <!-- Resources -->
      <nav aria-label={translation.footer.resources}>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">{translation.footer.resources}</h3>
        <ul class="space-y-3">
          <li><a href="/blog/category/review" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.blog.categories.review}</a></li>
          <li><a href="/blog/category/tutorial" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.blog.categories.tutorial}</a></li>
          <li><a href="/blog/category/trends" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.blog.categories.trends}</a></li>
          <li><a href="/compare" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">工具对比</a></li>
          <li><a href="/pricing" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">定价指南</a></li>
        </ul>
      </nav>

      <!-- Legal -->
      <nav aria-label={translation.footer.legal}>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">{translation.footer.legal}</h3>
        <ul class="space-y-3">
          <li><a href="/privacy" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.footer.privacy}</a></li>
          <li><a href="/terms" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.footer.terms}</a></li>
          <li><a href="/cookies" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.footer.cookie}</a></li>
          <li><a href="/contact" class="text-sm text-gray-600 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">{translation.footer.contact}</a></li>
        </ul>
      </nav>

      <!-- Newsletter -->
      <div>
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white uppercase tracking-wider mb-4">{translation.footer.newsletter}</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">{translation.footer.newsletterDesc}</p>
        <form class="flex flex-col gap-2" action="/api/newsletter" method="POST">
          <label for="newsletter-email" class="sr-only">{translation.footer.emailPlaceholder}</label>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            placeholder={translation.footer.emailPlaceholder}
            class="px-3 py-2 text-sm text-gray-900 dark:text-gray-100 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            required
            aria-label={translation.footer.emailPlaceholder}
          />
          <button
            type="submit"
            class="px-3 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors"
          >
            {translation.footer.subscribe}
          </button>
        </form>
        <p class="mt-2 text-xs text-gray-500 dark:text-gray-500">无垃圾邮件，随时退订。</p>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-gray-500 dark:text-gray-400">
          {translation.footer.copyright}
        </p>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          {translation.footer.madeWith} {translation.footer.madeWith.includes('Built') ? 'by' : '为'} 开发者与创作者
        </p>
      </div>
    </div>
  </div>
</footer>