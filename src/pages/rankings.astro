---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/config';
import { getTranslation, getPricingLabel } from '../i18n/server';
import toolsData from '../content/tools.json';

const locale: Locale = Astro.locals.locale || 'zh';
const translation = getTranslation(locale);

// 按评分排行的工具
const byRating = [...toolsData].sort((a, b) => b.rating - a.rating);
const topByRating = byRating.slice(0, 20);

// 按分类统计
const categories = Object.keys(translation.categories).filter(k => k !== 'title' && k !== 'subtitle' && k !== 'viewAll');
const catCounts = categories.map(catId => ({
  id: catId,
  name: translation.categories[catId as keyof typeof translation.categories]?.name || catId,
  count: toolsData.filter(t => t.category === catId).length,
})).filter(c => c.count > 0).sort((a, b) => b.count - a.count);

// 免费工具
const freeTools = toolsData.filter(t => t.pricing === 'free').sort((a, b) => b.rating - a.rating);
const topFree = freeTools.slice(0, 10);

// 精选工具（featured）
const featured = toolsData.filter(t => t.featured).sort((a, b) => b.rating - a.rating);

const totalTools = toolsData.length;

const pricingColors: Record<string, string> = {
  free: 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400',
  freemium: 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400',
  paid: 'bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-400',
};
---

<Layout title={`AI 工具排行榜 - ${translation.seo.title}`} description="AI 工具综合排行榜：评分排行、分类分布、免费工具推荐">
  <Header />

  <section class="py-16 bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-gray-950 dark:via-gray-900 dark:to-indigo-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">{translation.rankings.title}</h1>
        <p class="text-lg text-gray-600 dark:text-gray-400">{translation.rankings.subtitle}</p>
      </div>

      <!-- Stats Overview -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto mb-12">
        <div class="text-center p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">{totalTools}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">AI 工具总数</div>
        </div>
        <div class="text-center p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">{catCounts.length}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">分类数量</div>
        </div>
        <div class="text-center p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">{freeTools.length}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">免费工具</div>
        </div>
        <div class="text-center p-4 bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">{featured.length}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">精选推荐</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Rated -->
  <section class="py-16 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 flex items-center gap-3">
        <svg class="w-6 h-6 text-yellow-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
        {translation.rankings.topRated}
      </h2>
      <div class="overflow-hidden rounded-xl border border-gray-200 dark:border-gray-800">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">#</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">工具名称</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase hidden sm:table-cell">分类</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">评分</th>
              <th class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">定价</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 dark:divide-gray-800 bg-white dark:bg-gray-950">
            {topByRating.map((tool, i) => {
              const catInfo = translation.categories[tool.category as keyof typeof translation.categories];
              const pricingLabel = getPricingLabel(locale, tool.pricing);
              return (
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors">
                  <td class="px-4 py-3 whitespace-nowrap">
                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-sm font-bold {i < 3 ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400' : 'text-gray-500 dark:text-gray-400'}">
                      {i + 1}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                      <img src={tool.logo} alt="" class="w-8 h-8 rounded-lg object-cover bg-gray-100 dark:bg-gray-800" loading="lazy" onerror="this.style.display='none'" />
                      <div>
                        <a href={tool.affiliateUrl || tool.url} target="_blank" rel="noopener noreferrer {tool.affiliateUrl ? 'sponsored' : ''}" class="font-medium text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400">{tool.name}</a>
                        <p class="text-xs text-gray-500 dark:text-gray-400 truncate max-w-[200px] lg:max-w-xs">{tool.description}</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3 whitespace-nowrap hidden sm:table-cell">
                    <span class="text-sm text-gray-600 dark:text-gray-400">{catInfo?.name || tool.category}</span>
                  </td>
                  <td class="px-4 py-3 whitespace-nowrap text-center">
                    <span class="inline-flex items-center gap-1 text-sm font-semibold text-gray-900 dark:text-white">
                      <svg class="w-4 h-4 text-yellow-500 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                      {tool.rating.toFixed(1)}
                    </span>
                  </td>
                  <td class="px-4 py-3 whitespace-nowrap text-center">
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full {pricingColors[tool.pricing] || 'bg-gray-100 text-gray-700'}">
                      {pricingLabel}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Category Distribution -->
  <section class="py-16 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">{translation.rankings.byCategory}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
        {catCounts.map(cat => {
          const maxCount = catCounts[0].count;
          const widthPct = Math.max((cat.count / maxCount) * 100, 10);
          return (
            <a
              href={`/categories/${cat.id}`}
              class="p-4 bg-white dark:bg-gray-950 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-blue-200 dark:hover:border-blue-800 transition-all"
            >
              <div class="flex items-center justify-between mb-2">
                <h3 class="font-medium text-gray-900 dark:text-white text-sm">{cat.name}</h3>
                <span class="text-sm font-bold text-blue-600 dark:text-blue-400">{cat.count}</span>
              </div>
              <div class="w-full bg-gray-100 dark:bg-gray-800 rounded-full h-2">
                <div class="bg-gradient-to-r from-blue-500 to-purple-500 h-2 rounded-full transition-all" style={`width: ${widthPct}%`}></div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Free Tools -->
  <section class="py-16 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 flex items-center gap-3">
        <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        {translation.rankings.free}
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4">
        {topFree.map(tool => {
          const catInfo = translation.categories[tool.category as keyof typeof translation.categories];
          return (
            <a href={tool.affiliateUrl || tool.url} target="_blank" rel="noopener noreferrer {tool.affiliateUrl ? 'sponsored' : ''}" class="p-4 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-green-200 dark:hover:border-green-800 transition-all group">
              <div class="flex items-center gap-3 mb-2">
                <img src={tool.logo} alt="" class="w-8 h-8 rounded-lg object-cover bg-gray-100 dark:bg-gray-800" loading="lazy" onerror="this.style.display='none'" />
                <div>
                  <div class="font-medium text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 text-sm">{tool.name}</div>
                  <div class="text-xs text-gray-500">{catInfo?.name || tool.category}</div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <span class="flex items-center gap-1 text-xs text-yellow-600">
                  <svg class="w-3 h-3 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                  {tool.rating.toFixed(1)}
                </span>
                <span class="px-1.5 py-0.5 text-[10px] font-medium bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded-full">免费</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <Footer />
</Layout>