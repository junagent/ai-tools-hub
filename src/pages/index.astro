---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ToolCard from '../components/ToolCard.astro';
import type { Locale } from '../i18n/config';
import { getTranslation, getCategoryInfo } from '../i18n/server';
import toolsData from '../content/tools.json';

const locale: Locale = Astro.locals.locale || 'zh';
const translation = getTranslation(locale);

// 精选工具 + 按分类分组
const featured = toolsData.filter(t => t.featured);
const categories = ['chat', 'search', 'coding', 'image', 'video', 'audio', 'productivity', 'dev-tools'];
const toolsByCategory: Record<string, typeof toolsData> = {};
for (const cat of categories) {
  toolsByCategory[cat] = toolsData.filter(t => t.category === cat).slice(0, 4);
}

// 统计
const totalTools = toolsData.length;
const totalCategories = categories.length;
const avgRating = (toolsData.reduce((s, t) => s + t.rating, 0) / totalTools).toFixed(1);
---

<Layout>
  <Header />

  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-gray-950 dark:via-gray-900 dark:to-indigo-950">
    <!-- Background decoration -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-blue-200 dark:bg-blue-800/20 rounded-full blur-3xl opacity-50"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-purple-200 dark:bg-purple-800/20 rounded-full blur-3xl opacity-50"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28 lg:py-36">
      <div class="text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full text-sm font-medium mb-6">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          <span>{totalTools} {translation.hero.stats.tools}</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-gray-900 dark:text-white mb-6">
          {translation.hero.title}
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto leading-relaxed">
          {translation.hero.subtitle}
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/tools"
            class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-xl shadow-lg shadow-blue-500/25 hover:shadow-blue-500/40 transition-all"
          >
            {translation.hero.ctaPrimary}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          <a
            href="/categories"
            class="inline-flex items-center gap-2 px-8 py-3.5 text-base font-semibold text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-xl transition-all"
          >
            {translation.hero.ctaSecondary}
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-8 max-w-2xl mx-auto">
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900 dark:text-white">{totalTools}</div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{translation.hero.stats.tools}</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900 dark:text-white">{totalCategories}</div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{translation.hero.stats.categories}</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900 dark:text-white">10K+</div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{translation.hero.stats.users}</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-gray-900 dark:text-white">{avgRating}</div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">{translation.hero.stats.rating}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Grid -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{translation.categories.title}</h2>
        <p class="text-gray-600 dark:text-gray-400">{translation.categories.subtitle}</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
        {categories.map(catId => {
          const catInfo = getCategoryInfo(locale, catId);
          const catTools = toolsByCategory[catId] || [];
          return (
            <a
              href={`/categories/${catId}`}
              class="group relative p-6 bg-gray-50 dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 hover:border-blue-200 dark:hover:border-blue-800 hover:shadow-lg transition-all"
            >
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{catInfo.name}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{catInfo.description}</p>
              <span class="inline-block mt-3 text-xs font-medium text-blue-600 dark:text-blue-400">{catTools.length} {translation.categories.viewAll.split(' ').pop()}</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Featured Tools -->
  <section class="py-20 bg-gray-50 dark:bg-gray-900">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
            <span class="bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">{translation.common.featured}</span>
          </h2>
          <p class="text-gray-600 dark:text-gray-400 mt-2">{translation.hero.stats.tools}</p>
        </div>
        <a href="/tools" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300">
          {translation.categories.viewAll}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {featured.map(tool => (
          <ToolCard tool={tool} locale={locale} />
        ))}
      </div>

      <div class="text-center mt-10 sm:hidden">
        <a href="/tools" class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 rounded-xl hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">
          {translation.categories.viewAll}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- All Tools by Category -->
  <section class="py-20 bg-white dark:bg-gray-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{translation.nav.tools}</h2>
        <p class="text-gray-600 dark:text-gray-400">{totalTools} {translation.hero.stats.tools}</p>
      </div>

      {categories.map(catId => {
        const catInfo = getCategoryInfo(locale, catId);
        const catTools = toolsByCategory[catId] || [];
        if (catTools.length === 0) return null;
        return (
          <div class="mb-16 last:mb-0">
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class="text-xl font-semibold text-gray-900 dark:text-white">{catInfo.name}</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">{catInfo.description}</p>
              </div>
              <a
                href={`/categories/${catId}`}
                class="text-sm font-medium text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300"
              >
                {translation.categories.viewAll} →
              </a>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
              {catTools.map(tool => (
                <ToolCard tool={tool} locale={locale} />
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Footer -->
  <Footer />
</Layout>